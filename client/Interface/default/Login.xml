<?xml version="1.0" encoding="UTF-8" ?>
<XML ID="Login">
<Schema xmlns="MaietData" xmlns:dt="MaietDataTypes" />
<!-- Rewritten Login, Source Changes Necessary --> 
<!-- Base: Login Frame -->
<FRAME item="Login">
<FRAMELOOK>NullFrameLook</FRAMELOOK>
<BOUNDS>
<X>0</X>
<Y>0</Y>
<W>800</W>
<H>600</H>
</BOUNDS>
<TITLEBAR>false</TITLEBAR>
<RESIZABLE>false</RESIZABLE>
<FOCUSABLE>false</FOCUSABLE>
<VISIBLE>false</VISIBLE>
</FRAME>

	<PICTURE item="Login_BG" parent="Login">
<BOUNDS>
<X>0</X>
<Y>0</Y>
<W>800</W>
<H>600</H>
</BOUNDS>
<STRETCH/>
<BITMAP>loginbg2.png</BITMAP>
<VISIBLE>true</VISIBLE>
</PICTURE>

<!-- Frame: LoginFrame -->
<FRAME item="LoginFrame" parent="Login">
<FRAMELOOK>NullFrameLook</FRAMELOOK>
<BOUNDS>
<X>200</X>
<Y>330</Y>
<W>400</W>
<H>250</H>
</BOUNDS>
<RESIZABLE>true</RESIZABLE>
<FOCUSABLE>false</FOCUSABLE>
<VISIBLE>false</VISIBLE>
</FRAME>

<!-- Login: background -->
<PICTURE item="loginbg" parent="Login">
<BOUNDS>
<X>310</X>
<Y>200</Y>
<W>180</W>
<H>180</H>
</BOUNDS>
<STRETCH/>
<BITMAP>loginbg.png</BITMAP>
</PICTURE>

<!-- Label: LoginID -->
<PICTURE item ="BaseLogin" parent="Login">
<BOUNDS>
<X>341</X>
<Y>246</Y>
<W>120</W>
<H>25</H>
</BOUNDS>
<STRETCH/>
</PICTURE>
<!-- Edit: LoginID -->
<EDIT item="LoginID" parent="Login">
<BOUNDS>
<X>341</X>
<Y>246</Y>
<W>120</W>
<H>25</H>
</BOUNDS>
<TEXT></TEXT>
<VISIBLE>true</VISIBLE>
</EDIT>
<!-- Edit: Password -->
<EDIT item="LoginPassword" parent="Login">
<PASSWORD>true</PASSWORD>
<BOUNDS>
<X>341</X>
<Y>294</Y>
<W>120</W>
<H>25</H>
</BOUNDS>
<TEXT></TEXT>
<VISIBLE>true</VISIBLE>
</EDIT>

<!-- Login Button -->
<BMBUTTON item="LoginOK" parent="Login">
<BUTTONLOOK>NormalBmButtonLook</BUTTONLOOK>
<BOUNDS>
<X>324</X>
<Y>341</Y>
<W>153</W>
<H>25</H>
</BOUNDS>
<STRETCH/>
<DEFAULTKEY>ENTER</DEFAULTKEY>
<BITMAP type="up">login.png</BITMAP>
<BITMAP type="over">login_hover.png</BITMAP>
<BITMAP type="down">login_hover.png</BITMAP>
</BMBUTTON>
	<SERVERVIEW item="SelectedServer" parent="LoginFrame">
		<BOUNDS>
			<X>25</X>
			<Y>58</Y>
			<W>200</W>
			<H>120</H>
		</BOUNDS>
	<VISIBLE>false</VISIBLE>
	</SERVERVIEW>
<!-- Error: Login -->
<LABEL item="LoginError" parent="LoginFrame">
<TEXTCOLOR>
<R>200</R>
<G>0</G>
<B>0</B>
</TEXTCOLOR>
<BOUNDS>
<X>13</X>
<Y>230</Y>
<W>200</W>
<H>32</H>
</BOUNDS>
<TEXT></TEXT>
</LABEL>
<!-- Error: Connection -->
<LABEL item="Login_ConnectingMsg" parent="Login">
<FONT>FONTb11b</FONT>
<TEXTCOLOR>
<R>255</R>
<G>255</G>
<B>255</B>
</TEXTCOLOR>
<BOUNDS>
<X>200</X>
<Y>460</Y>
<W>400</W>
<H>25</H>
</BOUNDS>
<STRETCH/>
<VISIBLE>false</VISIBLE>
<TEXT></TEXT>
</LABEL>	
<!-- Login Hotkey -->
<BUTTON item="LoginOK" parent="LoginFrame">
<BUTTONLOOK>NormalButtonLook</BUTTONLOOK>
<BOUNDS>
<X>-1</X>
<Y>-1</Y>
<W>0</W>
<H>0</H>
</BOUNDS>
<DEFAULTKEY>ENTER</DEFAULTKEY>
</BUTTON>	
</XML>
